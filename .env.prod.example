# Production environment for docker-compose.prod.yml.
# Copy to .env.prod and fill in the secrets (deploy/install.sh can generate
# them for you). NEVER commit .env.prod.

# --- Database (docker-network only; no host port) ---
DB_USERNAME=quanta_mes
DB_PASSWORD=CHANGE_ME_STRONG
DB_NAME=p_mes

# --- Backend ---
# >= 32 chars; generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG_SECRET
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=7
PASSWORD_RESET_TTL_MINUTES=60
CORS_ORIGIN=https://quanta-mes.durdumehmetkeskin.space
# Public SPA base URL embedded into QR-code deep links.
APP_URL=https://quanta-mes.durdumehmetkeskin.space

# Initial admin (seeded idempotently on backend startup)
ADMIN_EMAIL=admin@durdumehmetkeskin.space
ADMIN_NAME=Administrator
ADMIN_PASSWORD=CHANGE_ME_STRONG

# --- Frontend (baked into the bundle at BUILD time; changing it requires
#     `docker compose ... up -d --build frontend`) ---
VITE_API_URL=https://quanta-mes-api.durdumehmetkeskin.space/api

# --- MinIO (docker-network only; no host port) ---
MINIO_ACCESS_KEY=quanta-mes
MINIO_SECRET_KEY=CHANGE_ME_STRONG
MINIO_BUCKET=p-mes

# --- pgAdmin (docker-network only; no host port) ---
PGADMIN_EMAIL=admin@durdumehmetkeskin.space
PGADMIN_PASSWORD=CHANGE_ME_STRONG

# --- Loopback host ports nginx proxies to (avoid 8090, 3010, 5432, 3000,
#     1337, 9000, 9001, 6379 — already used by other stacks on this server) ---
BACKEND_HOST_PORT=3020
FRONTEND_HOST_PORT=3021
