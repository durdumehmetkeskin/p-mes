{
  "expo": {
    "name": "QUA-MES",
    "slug": "p-mes-mobile",
    "version": "1.0.4",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "pmes",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0b1326",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pmes.mobile"
    },
    "android": {
      "package": "com.pmes.mobile",
      "versionCode": 5,
      "adaptiveIcon": {
        "backgroundColor": "#0b1326",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/splash-icon.png",
          "imageWidth": 260
        }
      ],
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow p-mes to unlock your saved session."
        }
      ],
      "expo-font",
      "expo-image",
      "expo-sharing",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow p-mes to scan QR codes on materials, tools and orders."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow p-mes to attach photos to projects and stages.",
          "cameraPermission": "Allow p-mes to attach photos from the camera."
        }
      ],
      "@config-plugins/react-native-blob-util",
      "@config-plugins/react-native-pdf",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ]
  }
}
