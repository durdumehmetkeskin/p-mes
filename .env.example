# Root docker-compose configuration. Adjust values as needed.

# Database
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=p_mes
DB_PORT=5432

# Backend
BACKEND_PORT=3000
JWT_SECRET=dev-only-insecure-secret-change-me-32chars!!
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=7
PASSWORD_RESET_TTL_MINUTES=60
CORS_ORIGIN=http://localhost:5173
# Public base URL of the frontend SPA, embedded as a deep link in generated QR codes.
APP_URL=http://localhost:5173

# Initial admin (seeded on backend startup; change before any real use)
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Administrator
ADMIN_PASSWORD=ChangeMe_Admin123

# Frontend (VITE_API_URL is baked into the bundle at build time)
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000/api

# pgAdmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
