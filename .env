# Root docker-compose configuration. Adjust values as needed.

# Database
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=p_mes
DB_PORT=5432

# Backend
BACKEND_PORT=3000
JWT_SECRET=br49NKai8ISOQcbbpVgFpdunYhzf07SWPoBIbDcrQRIGDItl
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=7
PASSWORD_RESET_TTL_MINUTES=60
CORS_ORIGIN=http://localhost:5173

# Initial admin (seeded on backend startup; change before any real use)
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Administrator
ADMIN_PASSWORD=Adm_330RTMot7HkV4IPRrxFP

# Frontend (VITE_API_URL is baked into the bundle at build time).
# Relative "/api" is resolved against the page origin at runtime, so the same
# build works behind any host serving the SPA (Traefik on http://localhost).
FRONTEND_PORT=5173
VITE_API_URL=/api

# Public SPA base URL used in QR-code deep links. After changing it:
# docker compose up -d backend
APP_URL=http://localhost

# Traefik local entrypoint
TRAEFIK_HTTP_PORT=80

# MinIO root credentials (also used by the backend client)
MINIO_ACCESS_KEY=pmes-minio-admin
MINIO_SECRET_KEY=z1cEcvwwnyS3ucNgQCl30Pz9LtNASPbfkx5wzaCM

# pgAdmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=SJ02GhPXwWaALWQEgR9Y
PGADMIN_PORT=5050
